# AstraHeal AI environment example
# Copy to .env on the machine running the GUI/backend.
# Do not commit real API keys.

# -----------------------------
# Runtime mode
# -----------------------------
AIQA_RUNTIME_MODE=local_pc
# local_pc | central_vm | vm_with_workers
AIQA_GUI_HOST=127.0.0.1
AIQA_GUI_PORT=8080

# -----------------------------
# AI provider selection
# -----------------------------
# codex | deepseek | openai | ollama | deterministic
AIQA_DEFAULT_PROVIDER=deepseek
CODEGEN_PROVIDER=deepseek
AIQA_CODEX_PATCH_LOCATION=central_only

# Codex CLI: requires `codex login` on the GUI/backend machine only.
CODEX_COMMAND=codex
CODEX_TIMEOUT_SECONDS=600
CODEX_SANDBOX=workspace-write

# DeepSeek API: no Codex login required.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# OpenAI API: no Codex login required.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini

# Ollama local model.
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3

# -----------------------------
# Existing Playwright framework
# -----------------------------
AIQA_FRAMEWORK_PATH=D:\AI_QA_WORKSPACE\client-playwright-framework
AIQA_CENTRAL_SHARED_FRAMEWORK_PATH=\\10.252.41.177\AIQA_Frameworks\client-playwright-framework
BASE_URL=
PLAYWRIGHT_TEST_ID_ATTRIBUTE=data-test

# -----------------------------
# Worker-agent mode
# -----------------------------
AIQA_ENABLE_WORKER_AGENTS=true
AIQA_WORKER_MODE=central_shared_framework
AIQA_AGENT_ROLE=browser_execution

# -----------------------------
# Optional runtime services
# -----------------------------
PLAYWRIGHT_MCP_ENABLED=true
PLAYWRIGHT_MCP_HEADLESS=true
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1,host.docker.internal

# Optional Perplexity API provider for web-grounded RCA/fix-plan guidance.
# Direct framework file patching remains Codex CLI/human-approved for auditability.
PERPLEXITY_API_KEY=
PERPLEXITY_BASE_URL=https://api.perplexity.ai
PERPLEXITY_MODEL=sonar

# VM/VDI responsiveness helpers
ASTRAHEAL_AI_STUCK_NOTICE_SECONDS=90
ASTRAHEAL_MAX_EXPLICIT_WAIT_MS=30000
ASTRAHEAL_CODEX_PATCH_TIMEOUT_SECONDS=300
